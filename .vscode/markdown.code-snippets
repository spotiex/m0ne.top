{
	"Blog Image Center": {
		"scope": "markdown,mdx",
		"prefix": "imgc",
		"description": "Insert a centered blog image with optional width class.",
		"body": [
			"<img class=\"img-center ${1|img-40,img-50,img-70|}\" src=\"${2}\" alt=\"${3}\" />"
		]
	},
