	"Blog Image Caption": {
		"scope": "markdown,mdx",
		"prefix": "imgcap",
		"description": "Insert a blog image with a semantic caption.",
		"body": [
			"<figure class=\"img-figure img-center ${1|img-40,img-50,img-70|}\">",
			"\t<img src=\"${2}\" alt=\"${3}\" />",
			"\t<figcaption>${4}</figcaption>",
			"</figure>"
		]
	},
