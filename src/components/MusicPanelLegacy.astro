---
import type { NeteaseTrack } from '@src/lib/music/netease';

interface Props {
  tracks: NeteaseTrack[];
}

const { tracks } = Astro.props as Props;
const firstTrack = tracks[0];
---

<section class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5 text-zinc-900 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100" data-music-panel>
  <div class="mb-4 flex items-center justify-between gap-3">
    <h2 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">喜欢的歌 / Music</h2>
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="rounded-md border border-zinc-300 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-200 dark:hover:bg-zinc-700"
        data-music-refresh
      >
        刷新
      </button>
      <button
        type="button"
        class="rounded-md border border-zinc-300 px-2 py-1 text-xs text-zinc-700 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-200 dark:hover:bg-zinc-700"
        data-music-random-play
      >
        随机播放
      </button>
    </div>
  </div>

  {
    tracks.length === 0 ? (
      <p class="text-sm text-zinc-600 dark:text-zinc-300">
        音乐列表暂不可用。请先在 <code>.env</code> 配置 <code>NETEASE_MUSIC_U</code>、<code>NETEASE_CSRF</code>（或
        <code>NETEASE_COOKIE</code>）和 <code>NETEASE_PLAYLIST_ID</code>。
      </p>
    ) : (
      <>
        <ul class="space-y-3" data-music-list>
          {
            tracks.map((track, index) => (
              <li>
                <button
                  class="music-trigger grid w-full grid-cols-[52px_1fr_auto] items-center gap-3 rounded-xl p-2 text-left transition hover:bg-zinc-100 dark:hover:bg-zinc-700"
                  data-url={track.playUrl}
                  data-name={track.name}
                  data-artist={track.artist}
                  data-id={track.id}
                  data-index={index}
                  aria-label={`播放 ${track.name}`}
                >
                  <img src={track.cover} alt={track.name} class="h-12 w-12 rounded-md border border-zinc-200 object-cover dark:border-zinc-600" loading="lazy" />
                  <span>
                    <strong class="block text-sm font-semibold text-zinc-900 dark:text-zinc-100">{track.name}</strong>
                    <span class="block text-xs text-zinc-600 dark:text-zinc-300">{track.artist}</span>
                  </span>
                  <time class="text-xs tabular-nums text-zinc-500 dark:text-zinc-300">{track.duration}</time>
                </button>
              </li>
            ))
          }
        </ul>

        <div class="mt-4 rounded-xl border border-zinc-200 bg-white p-3 dark:border-zinc-600 dark:bg-zinc-900">
          <p id="music-now-playing" class="mb-2 text-center text-sm text-zinc-700 dark:text-zinc-200">
            Playing: {firstTrack ? `${firstTrack.name} - ${firstTrack.artist}` : '--'}
          </p>
          <audio id="music-audio" class="w-full" controls preload="none" src={firstTrack?.playUrl}></audio>
        </div>
      </>
    )
  }
</section>

<script is:inline>
  const STORAGE_KEY = 'global_music_player_state_v1';
  const panel = document.querySelector('[data-music-panel]');
  if (panel) {
    const audio = panel.querySelector('#music-audio');
    const nowPlaying = panel.querySelector('#music-now-playing');
    const refreshBtn = panel.querySelector('[data-music-refresh]');
    const randomPlayBtn = panel.querySelector('[data-music-random-play]');
    const list = panel.querySelector('[data-music-list]');
    let currentIndex = 0;
    let lastSavedAt = 0;

    const setNowPlaying = (name, artist) => {
      if (!nowPlaying) return;
      nowPlaying.textContent = `Playing: ${name} - ${artist}`;
    };

    const playTrack = (button, index) => {
      const url = button.getAttribute('data-url');
      const name = button.getAttribute('data-name');
      const artist = button.getAttribute('data-artist');
      if (!audio || !url) return;
      if (audio.src !== url) {
        audio.src = url;
      }
      if (name && artist) {
        setNowPlaying(name, artist);
      }
      if (typeof index === 'number' && Number.isFinite(index)) {
        currentIndex = index;
      }
      audio.play().catch(() => {});
    };

    const escapeHTML = (value) =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const bindTriggers = () => {
      const triggers = panel.querySelectorAll('.music-trigger');
      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const index = Number(trigger.getAttribute('data-index') ?? '0');
          playTrack(trigger, index);
        });
      });
      return Array.from(triggers);
    };

    const buildPlaylistSnapshot = () =>
      currentTriggers.map((trigger, index) => ({
        id: Number(trigger.getAttribute('data-id') ?? '0'),
        name: trigger.getAttribute('data-name') ?? '',
        artist: trigger.getAttribute('data-artist') ?? '',
        playUrl: trigger.getAttribute('data-url') ?? '',
        duration: trigger.querySelector('time')?.textContent?.trim() ?? '',
        cover: trigger.querySelector('img')?.getAttribute('src') ?? '',
        index,
      }));

    const saveState = () => {
      if (!audio) return;
      const current = currentTriggers[currentIndex];
      const payload = {
        currentTrackId: Number(current?.getAttribute('data-id') ?? 0),
        currentIndex,
        currentTime: Number(audio.currentTime || 0),
        isPlaying: !audio.paused,
        playlist: buildPlaylistSnapshot(),
        updatedAt: Date.now(),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
    };

    const trySaveState = () => {
      const now = Date.now();
      if (now - lastSavedAt < 800) return;
      lastSavedAt = now;
      saveState();
    };

    const playTrackByIndex = (index) => {
      if (currentTriggers.length === 0) return;
      const safeIndex = ((index % currentTriggers.length) + currentTriggers.length) % currentTriggers.length;
      const target = currentTriggers[safeIndex];
      playTrack(target, safeIndex);
      saveState();
    };

    let currentTriggers = bindTriggers();

    if (randomPlayBtn) {
      randomPlayBtn.addEventListener('click', () => {
        if (currentTriggers.length === 0) return;
        const pickIndex = Math.floor(Math.random() * currentTriggers.length);
        playTrackByIndex(pickIndex);
      });
    }

    if (audio) {
      audio.addEventListener('ended', () => {
        if (currentTriggers.length === 0) return;
        const nextIndex = (currentIndex + 1) % currentTriggers.length;
        playTrackByIndex(nextIndex);
      });
      audio.addEventListener('timeupdate', trySaveState);
      audio.addEventListener('play', saveState);
      audio.addEventListener('pause', saveState);
    }

    if (refreshBtn && list) {
      refreshBtn.addEventListener('click', async () => {
        const wasPlaying = !!audio && !audio.paused;
        refreshBtn.setAttribute('disabled', 'true');
        refreshBtn.textContent = '刷新中...';
        try {
          const res = await fetch('/api/music/random.json', { cache: 'no-store' });
          if (!res.ok) throw new Error('failed');
          const data = await res.json();
          const tracks = Array.isArray(data?.tracks) ? data.tracks : [];
          list.innerHTML = tracks
            .map(
              (track, index) => `
              <li>
                <button
                  class="music-trigger grid w-full grid-cols-[52px_1fr_auto] items-center gap-3 rounded-xl p-2 text-left transition hover:bg-zinc-100 dark:hover:bg-zinc-700"
                  data-url="${escapeHTML(track.playUrl ?? '')}"
                  data-name="${escapeHTML(track.name ?? '')}"
                  data-artist="${escapeHTML(track.artist ?? '')}"
                  data-id="${escapeHTML(track.id ?? 0)}"
                  data-index="${index}"
                  aria-label="播放 ${escapeHTML(track.name ?? '')}"
                >
                  <img src="${escapeHTML(track.cover ?? '')}" alt="${escapeHTML(track.name ?? '')}" class="h-12 w-12 rounded-md border border-zinc-200 object-cover dark:border-zinc-600" loading="lazy" />
                  <span>
                    <strong class="block text-sm font-semibold text-zinc-900 dark:text-zinc-100">${escapeHTML(track.name ?? '')}</strong>
                    <span class="block text-xs text-zinc-600 dark:text-zinc-300">${escapeHTML(track.artist ?? '')}</span>
                  </span>
                  <time class="text-xs tabular-nums text-zinc-500 dark:text-zinc-300">${escapeHTML(track.duration ?? '')}</time>
                </button>
              </li>`,
            )
            .join('');
          currentTriggers = bindTriggers();
          currentIndex = 0;
          if (audio && tracks[0]?.playUrl) {
            audio.src = tracks[0].playUrl;
            if (wasPlaying) {
              audio.play().catch(() => {});
            }
          }
          if (tracks[0]) {
            setNowPlaying(tracks[0].name ?? '--', tracks[0].artist ?? '--');
            saveState();
          } else if (audio) {
            audio.pause();
            audio.removeAttribute('src');
            audio.load();
            if (nowPlaying) nowPlaying.textContent = 'Playing: --';
            saveState();
          }
        } catch (error) {
          console.error('[music] refresh failed', error);
        } finally {
          refreshBtn.removeAttribute('disabled');
          refreshBtn.textContent = '刷新';
        }
      });
    }
  }
</script>

<style is:global>
  [data-music-panel] audio {
    accent-color: #52525b;
  }

  .dark [data-music-panel] audio {
    color-scheme: dark;
    accent-color: #a1a1aa;
    background-color: #18181b;
    border-radius: 9999px;
  }

  .dark [data-music-panel] audio::-webkit-media-controls-enclosure {
    background-color: #18181b;
    border-radius: 9999px;
  }

  .dark [data-music-panel] audio::-webkit-media-controls-panel {
    background-color: #18181b;
  }
</style>
