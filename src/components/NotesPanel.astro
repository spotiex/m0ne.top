---
import type { CollectionEntry } from 'astro:content';

interface Props {
	notes: CollectionEntry<'notes'>[];
}

const { notes = [] } = Astro.props;
---

<section class='not-prose'>
	<div class='flex justify-between gap-2 border-b mb-3 dark:border-b-zinc-700'>
		<h2 class='text-lg font-bold mb-3'>随笔 / Fragments</h2>
		<a href='/notes/' class='inline-block py-2 underline dark:prose-invert'>All notes &raquo;</a>
	</div>

	{
		notes.length === 0 ? (
			<p class='text-sm text-zinc-600 dark:text-zinc-400'>
				暂未配置随笔数据。请在 <code>src/content/notes</code> 添加 Markdown 文件。
			</p>
		) : (
			<div class='notes-grid'>
				{
					notes.slice(0, 6).map((note, index) => (
						<a class={`note-card note-tone-${index % 3}`} href={`/notes/${note.id}/`}>
							<h3 class='note-title'>{note.data.title}</h3>
							<p class='note-content'>{note.data.description}</p>
							<div class='note-meta'>
								<time>{note.data.pubDate.toLocaleDateString('zh-CN')}</time>
								{note.data.mood && <span>{note.data.mood}</span>}
							</div>
						</a>
					))
				}
			</div>
		)
	}
</section>

<style>
	.notes-grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 0.8rem;
	}

	@media (min-width: 768px) {
		.notes-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1rem;
		}
	}

	@media (min-width: 1100px) {
		.notes-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.note-card {
		position: relative;
		display: block;
		border-radius: 0.95rem;
		padding: 1rem 1.05rem 0.95rem;
		border: 1px solid rgb(228 228 231);
		background: rgb(250 250 250 / 0.92);
		transition: transform 0.18s ease, box-shadow 0.18s ease;
		text-decoration: none;
	}

	.note-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 18px rgb(15 23 42 / 0.08);
	}

	.note-title {
		margin: 0 0 0.45rem;
		font-size: 0.95rem;
		line-height: 1.45;
		font-weight: 600;
		color: rgb(24 24 27);
	}

	.note-content {
		margin: 0 0 0.75rem;
		line-height: 1.7;
		font-size: 0.92rem;
		color: rgb(63 63 70);
	}

	.note-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.78rem;
		color: rgb(113 113 122);
		gap: 0.7rem;
	}

	.note-tone-0 {
		background: linear-gradient(180deg, rgb(250 250 250), rgb(244 244 245));
	}

	.note-tone-1 {
		background: linear-gradient(180deg, rgb(249 250 251), rgb(241 245 249));
	}

	.note-tone-2 {
		background: linear-gradient(180deg, rgb(252 252 252), rgb(245 245 244));
	}

	:global(html.dark) .note-card {
		border-color: rgb(63 63 70);
		box-shadow: none;
	}

	:global(html.dark) .note-content {
		color: rgb(228 228 231);
	}

	:global(html.dark) .note-title {
		color: rgb(244 244 245);
	}

	:global(html.dark) .note-meta {
		color: rgb(161 161 170);
	}

	:global(html.dark) .note-tone-0 {
		background: linear-gradient(180deg, rgb(39 39 42 / 0.9), rgb(24 24 27 / 0.9));
	}

	:global(html.dark) .note-tone-1 {
		background: linear-gradient(180deg, rgb(51 65 85 / 0.45), rgb(24 24 27 / 0.9));
	}

	:global(html.dark) .note-tone-2 {
		background: linear-gradient(180deg, rgb(63 63 70 / 0.5), rgb(24 24 27 / 0.88));
	}
</style>
