---
import type { GalleryItem } from '../consts';

interface Props {
	photos: GalleryItem[];
}

const { photos = [] } = Astro.props;
const shuffle = <T,>(items: T[]) => {
	const next = [...items];
	for (let index = next.length - 1; index > 0; index -= 1) {
		const randomIndex = Math.floor(Math.random() * (index + 1));
		[next[index], next[randomIndex]] = [next[randomIndex], next[index]];
	}
	return next;
};

const randomizedPhotos = shuffle(photos);
const topRowPhotos = randomizedPhotos.filter((_, index) => index % 2 === 0);
const bottomRowPhotos = randomizedPhotos.filter((_, index) => index % 2 === 1);
const topRowLoopPhotos = topRowPhotos.length > 0 ? [...topRowPhotos, ...topRowPhotos] : [];
const bottomRowLoopPhotos = bottomRowPhotos.length > 0 ? [...bottomRowPhotos, ...bottomRowPhotos] : [];
---

<section class='not-prose'>
	<div class='flex justify-between gap-2 border-b mb-3 dark:border-b-zinc-700'>
		<h2 class='text-lg font-bold mb-3'>光学视界 / Gallery</h2>
		<a href='/photos/' class='inline-block py-2 underline dark:prose-invert'>All photos &raquo;</a>
	</div>

		{
			photos.length === 0 ? (
				<p class='text-sm text-zinc-600 dark:text-zinc-400'>
					暂未读取到图片数据，请检查 gallery index 或图床配置。
				</p>
			) : (
			<div class='gallery-stack'>
				<div class='gallery-marquee'>
					<div class='gallery-track'>
						{
							topRowLoopPhotos.map((item) => (
								<article class='gallery-card'>
									<img src={item.src} alt={item.alt} loading='lazy' />
									{item.title && <p>{item.title}</p>}
								</article>
							))
						}
					</div>
				</div>
				{
					bottomRowLoopPhotos.length > 0 && (
						<div class='gallery-marquee'>
							<div class='gallery-track gallery-track-reverse'>
								{
									bottomRowLoopPhotos.map((item) => (
										<article class='gallery-card'>
											<img src={item.src} alt={item.alt} loading='lazy' />
											{item.title && <p>{item.title}</p>}
										</article>
									))
								}
							</div>
						</div>
					)
				}
			</div>
		)
	}
</section>

<style>
	.gallery-stack {
		display: grid;
		gap: 0.9rem;
	}

	.gallery-marquee {
		overflow: hidden;
		mask-image: linear-gradient(to right, transparent 0, black 5%, black 95%, transparent 100%);
	}

	.gallery-track {
		display: flex;
		gap: 0.9rem;
		width: max-content;
		animation: gallery-scroll 33.34s linear infinite;
	}

	.gallery-marquee:hover .gallery-track {
		animation-play-state: paused;
	}

	.gallery-track-reverse {
		animation-name: gallery-scroll-reverse;
	}

	.gallery-card {
		width: fit-content;
		flex: 0 0 auto;
		border-radius: 0.81rem;
		overflow: hidden;
		background: rgb(250 250 250);
		border: 1px solid rgb(228 228 231);
	}

	.gallery-card img {
		display: block;
		width: auto;
		height: clamp(180px, 19vw, 252px);
		max-width: min(72vw, 420px);
		object-fit: contain;
	}

	.gallery-card p {
		margin: 0;
		padding: 0.468rem 0.63rem;
		font-size: 0.747rem;
		color: rgb(82 82 91);
	}

	:global(html.dark) .gallery-card {
		background: rgb(24 24 27);
		border-color: rgb(63 63 70);
	}

	:global(html.dark) .gallery-card p {
		color: rgb(212 212 216);
	}

	@keyframes gallery-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	@keyframes gallery-scroll-reverse {
		from {
			transform: translateX(-50%);
		}
		to {
			transform: translateX(0);
		}
	}
</style>
