---
import { Image } from 'astro:assets';
import ME from '@src/assets/img/me.jpg';
import { GITHUB_PROFILE_URL } from '@src/consts';

type PicSize = 'sm' | 'md' | 'lg';
interface Props {
	picSize: PicSize;
}
const { picSize } = Astro.props;
---

<div class='flex gap-4 items-center leading-tight not-prose'>
	<a
		href={GITHUB_PROFILE_URL}
		target='_blank'
		rel='noopener noreferrer'
		class:list={[
			'rounded-full overflow-hidden shrink-0',
			{ 'w-12 h-12': picSize === 'sm' },
			{ 'w-[70px] h-[70px]': picSize === 'md' },
			{ 'w-[90px] h-[90px]': picSize === 'lg' }
		]}
	>
		<Image src={ME} alt='m0ne' class='block h-full w-full object-cover' />
		<!-- Revert option: <Image src={ME} alt='m0ne' /> -->
	</a>
	<div>
		<div>
			<a
				href={GITHUB_PROFILE_URL}
				class='block font-bold text-inherit hover:text-[var(--link-color)]'
				target='_blank'
				rel='noopener noreferrer'
			>
				m0ne
			</a>
		</div>
		<small class='avatar__subtitle'>硕士研究生在读</small>
	</div>
</div>
