---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import { HOME_GALLERY_ITEMS, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const galleryTags = ['全部', ...new Set(HOME_GALLERY_ITEMS.flatMap((item) => item.tags ?? []))];

const formatPhotoDate = (value?: string) => {
	if (!value) return '';
	const normalized = value.trim().replace(/[.]/g, '-').replace(/\//g, '-');
	const parts = normalized.split('-').map((part) => part.trim()).filter(Boolean);
	if (parts.length < 3) return value;

	const [year, month, day] = parts;
	const numericYear = Number(year);
	const numericMonth = Number(month);
	const numericDay = Number(day);

	if (!Number.isFinite(numericYear) || !Number.isFinite(numericMonth) || !Number.isFinite(numericDay)) {
		return value;
	}

	return `${numericYear}年${numericMonth}月${numericDay}日`;
};
---

<BaseLayout title={`Photos - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='mb-8'>
			<h1 class='text-3xl md:text-4xl font-bold mb-2'>光阴故事，目之所及的二进制</h1>

			<Prose>
				<p class='text-zinc-700 dark:text-zinc-300'>
					这里展示的是画廊总览，照片存储采用了<a href="https://cloudflare.com/products/r2" target='_blank'> Cloudflare R2 </a> 图床链接。
				</p>
			</Prose>
		</div>

		<div class='mb-6 flex flex-wrap gap-2' id='photo-filters'>
			{
				galleryTags.map((tag) => (
					<button
						type='button'
						class:list={[
							'photo-filter rounded-full border px-3 py-1.5 text-sm transition-colors',
							tag === '全部'
								? 'border-zinc-900 bg-zinc-900 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900'
								: 'border-zinc-300 text-zinc-700 hover:border-zinc-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500'
						]}
						data-photo-filter={tag}
						aria-pressed={tag === '全部' ? 'true' : 'false'}
					>
						{tag}
					</button>
				))
			}
		</div>

		<div class='mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'>
			<p id='photo-pagination-summary' class='text-sm text-zinc-600 dark:text-zinc-300'>共 0 张图片</p>
			<label class='flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300'>
				<span>每页显示</span>
				<select
					id='photo-page-size'
					class='rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-sm text-zinc-900 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100'
				>
					<option value='12' selected>12</option>
					<option value='24'>24</option>
					<option value='36'>36</option>
				</select>
			</label>
		</div>

		
		<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4' id='photo-grid'>
			{
				HOME_GALLERY_ITEMS.map((item, index) => (
					<figure
						class='photo-card rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900'
						data-photo-tags={(item.tags ?? []).join('|')}
					>
						<button
							type='button'
							class='photo-trigger block w-full'
							data-photo-index={index}
							data-photo-src={item.src}
							data-photo-alt={item.alt}
							data-photo-title={item.title ?? ''}
							data-photo-tags={(item.tags ?? []).join('|')}
							aria-label={`查看大图 ${item.title || item.alt || `#${index + 1}`}`}
						>
							<div class='photo-trigger__media'>
								<img src={item.src} alt={item.alt} loading='lazy' class='w-full aspect-[4/3] object-cover' />
								{
									item.description && (
										<span class='photo-hover-note'>
											{item.description}
										</span>
									)
								}
							</div>
						</button>
						{(item.title || item.date || (item.tags ?? []).length > 0) && (
							<figcaption class='px-3 py-2 text-sm text-zinc-600 dark:text-zinc-300'>
								<div class='flex flex-wrap items-start gap-2'>
									<div class='min-w-0'>
										{item.title && <span>{item.title}</span>}
										{
											item.date && <span class='ml-2 text-xs text-zinc-500 dark:text-zinc-400'>{formatPhotoDate(item.date)}</span>
										}
									</div>
									{
										(item.tags ?? []).length > 0 && (
											<div class='ml-auto flex flex-wrap justify-end gap-1.5'>
												{
													(item.tags ?? []).map((tag) => (
														<span class='rounded-full bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300'>
															{tag}
														</span>
													))
												}
											</div>
										)
									}
								</div>
							</figcaption>
						)}
					</figure>
				))
			}
		</div>

		<div id='photo-pagination' class='mt-8 flex flex-wrap items-center justify-center gap-2'></div>
	</div>

	<div id='photo-lightbox' class='photo-lightbox' aria-hidden='true' hidden>
		<div class='photo-lightbox__backdrop' data-lightbox-close></div>
		<div class='photo-lightbox__dialog' role='dialog' aria-modal='true' aria-label='图片预览'>
			<button type='button' class='photo-lightbox__close' data-lightbox-close aria-label='关闭预览'>×</button>
			<button type='button' class='photo-lightbox__nav photo-lightbox__nav--prev' data-lightbox-prev aria-label='上一张'>‹</button>
			<figure class='photo-lightbox__figure'>
				<img id='photo-lightbox-image' src='' alt='' class='photo-lightbox__image' />
				<figcaption id='photo-lightbox-caption' class='photo-lightbox__caption'></figcaption>
			</figure>
			<button type='button' class='photo-lightbox__nav photo-lightbox__nav--next' data-lightbox-next aria-label='下一张'>›</button>
		</div>
	</div>
</BaseLayout>

<script is:inline>
	const initPhotoFilters = () => {
		const filterButtons = Array.from(document.querySelectorAll('[data-photo-filter]'));
		const photoCards = Array.from(document.querySelectorAll('.photo-card'));
		const pageSizeSelect = document.getElementById('photo-page-size');
		const pagination = document.getElementById('photo-pagination');
		const summary = document.getElementById('photo-pagination-summary');
		if (filterButtons.length === 0 || photoCards.length === 0) return;
		if (document.body.dataset.photoFilterBound === '1') return;
		document.body.dataset.photoFilterBound = '1';

		let activeTag = '全部';
		let currentPage = 1;
		let pageSize = pageSizeSelect instanceof HTMLSelectElement ? Number(pageSizeSelect.value || '12') : 12;

		const updateVisibleCards = () => {
			const filteredCards = photoCards.filter((card) => {
				const rawTags = card.getAttribute('data-photo-tags') || '';
				const tags = rawTags ? rawTags.split('|') : [];
				return activeTag === '全部' || tags.includes(activeTag);
			});

			const totalItems = filteredCards.length;
			const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
			if (currentPage > totalPages) currentPage = totalPages;
			const startIndex = (currentPage - 1) * pageSize;
			const endIndex = startIndex + pageSize;

			photoCards.forEach((card) => {
				card.hidden = true;
			});

			filteredCards.forEach((card, index) => {
				card.hidden = !(index >= startIndex && index < endIndex);
			});

			if (summary instanceof HTMLElement) {
				summary.textContent = `共 ${totalItems} 张图片，第 ${currentPage} / ${totalPages} 页`;
			}

			if (!(pagination instanceof HTMLElement)) return;

			const renderButton = (label, nextPage, disabled = false, isActive = false) => `
				<button
					type="button"
					class="photo-page-btn rounded-full border px-3 py-1.5 text-sm transition-colors ${
						isActive
							? 'border-zinc-700 bg-zinc-700 text-white dark:border-zinc-200 dark:bg-zinc-200 dark:text-zinc-900'
							: 'border-zinc-300 text-zinc-700 dark:border-zinc-700 dark:text-zinc-300'
					} ${disabled ? 'cursor-not-allowed opacity-50' : 'hover:border-zinc-500 dark:hover:border-zinc-500'}"
					data-photo-page="${nextPage}"
					${disabled ? 'disabled' : ''}
				>
					${label}
				</button>
			`;

			const pageButtons = [];
			pageButtons.push(renderButton('上一页', currentPage - 1, currentPage === 1));
			for (let page = 1; page <= totalPages; page += 1) {
				pageButtons.push(renderButton(String(page), page, false, page === currentPage));
			}
			pageButtons.push(renderButton('下一页', currentPage + 1, currentPage === totalPages));
			pagination.innerHTML = pageButtons.join('');

			pagination.querySelectorAll('[data-photo-page]').forEach((button) => {
				button.addEventListener('click', () => {
					const nextPage = Number(button.getAttribute('data-photo-page') || '1');
					if (!Number.isFinite(nextPage)) return;
					currentPage = Math.min(Math.max(1, nextPage), totalPages);
					updateVisibleCards();
				});
			});
		};

		const setFilter = (nextTag) => {
			activeTag = nextTag;
			currentPage = 1;

			filterButtons.forEach((button) => {
				const isActive = button.getAttribute('data-photo-filter') === activeTag;
				button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
				button.classList.toggle('border-zinc-900', isActive);
				button.classList.toggle('bg-zinc-900', isActive);
				button.classList.toggle('text-white', isActive);
				button.classList.toggle('dark:border-zinc-100', isActive);
				button.classList.toggle('dark:bg-zinc-100', isActive);
				button.classList.toggle('dark:text-zinc-900', isActive);
				button.classList.toggle('border-zinc-300', !isActive);
				button.classList.toggle('text-zinc-700', !isActive);
				button.classList.toggle('hover:border-zinc-500', !isActive);
				button.classList.toggle('dark:border-zinc-700', !isActive);
				button.classList.toggle('dark:text-zinc-300', !isActive);
				button.classList.toggle('dark:hover:border-zinc-500', !isActive);
			});
			updateVisibleCards();
		};

		filterButtons.forEach((button) => {
			button.addEventListener('click', () => {
				setFilter(button.getAttribute('data-photo-filter') || '全部');
			});
		});

		pageSizeSelect?.addEventListener('change', () => {
			if (!(pageSizeSelect instanceof HTMLSelectElement)) return;
			pageSize = Number(pageSizeSelect.value || '12');
			currentPage = 1;
			updateVisibleCards();
		});

		setFilter('全部');

		document.addEventListener(
			'astro:before-swap',
			() => {
				document.body.dataset.photoFilterBound = '0';
			},
			{ once: true }
		);
	};

	const initPhotoLightbox = () => {
		const triggers = Array.from(document.querySelectorAll('.photo-trigger'));
		const lightbox = document.getElementById('photo-lightbox');
		const image = document.getElementById('photo-lightbox-image');
		const caption = document.getElementById('photo-lightbox-caption');
		if (!lightbox || !image || !caption || triggers.length === 0) return;
		if (lightbox.dataset.bound === '1') return;
		lightbox.dataset.bound = '1';

		let currentIndex = 0;
		const getActiveTriggers = () =>
			triggers.filter((trigger) => !(trigger.closest('.photo-card') instanceof HTMLElement && trigger.closest('.photo-card').hidden));

		const render = (index) => {
			const activeTriggers = getActiveTriggers();
			if (activeTriggers.length === 0) return;
			const safeIndex = (index + activeTriggers.length) % activeTriggers.length;
			const trigger = activeTriggers[safeIndex];
			const src = trigger.getAttribute('data-photo-src') || '';
			const alt = trigger.getAttribute('data-photo-alt') || '';
			const title = trigger.getAttribute('data-photo-title') || '';
			currentIndex = safeIndex;
			image.setAttribute('src', src);
			image.setAttribute('alt', alt || title || `photo-${safeIndex + 1}`);
			caption.textContent = title || alt || '';
		};

		const open = (index) => {
			const activeTriggers = getActiveTriggers();
			const safeIndex = Math.max(activeTriggers.findIndex((trigger) => trigger === triggers[index]), 0);
			render(safeIndex);
			lightbox.hidden = false;
			lightbox.setAttribute('aria-hidden', 'false');
			document.body.classList.add('photo-lightbox-open');
		};

		const close = () => {
			lightbox.hidden = true;
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.classList.remove('photo-lightbox-open');
			image.setAttribute('src', '');
		};

		const step = (delta) => {
			render(currentIndex + delta);
		};

		triggers.forEach((trigger, index) => {
			trigger.addEventListener('click', () => open(index));
		});

		lightbox.querySelectorAll('[data-lightbox-close]').forEach((element) => {
			element.addEventListener('click', close);
		});

		lightbox.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => step(-1));
		lightbox.querySelector('[data-lightbox-next]')?.addEventListener('click', () => step(1));

		document.addEventListener('keydown', (event) => {
			if (lightbox.hidden) return;
			if (event.key === 'Escape') close();
			if (event.key === 'ArrowLeft') step(-1);
			if (event.key === 'ArrowRight') step(1);
		});

		document.addEventListener(
			'astro:before-swap',
			() => {
				close();
				lightbox.dataset.bound = '0';
			},
			{ once: true }
		);
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initPhotoFilters();
			initPhotoLightbox();
		}, { once: true });
	} else {
		initPhotoFilters();
		initPhotoLightbox();
	}
	document.addEventListener('astro:page-load', initPhotoFilters);
	document.addEventListener('astro:page-load', initPhotoLightbox);
</script>

<style>
	.photo-trigger {
		border: 0;
		padding: 0;
		background: transparent;
		cursor: zoom-in;
	}

	.photo-trigger__media {
		position: relative;
	}

	.photo-hover-note {
		position: absolute;
		left: 0.75rem;
		right: 0.75rem;
		bottom: 0.75rem;
		opacity: 0;
		transform: translateY(6px);
		border-radius: 0.85rem;
		background: rgb(24 24 27 / 0.82);
		color: rgb(244 244 245);
		padding: 0.55rem 0.7rem;
		font-size: 0.78rem;
		line-height: 1.55;
		text-align: left;
		backdrop-filter: blur(6px);
		transition: opacity 160ms ease, transform 160ms ease;
		pointer-events: none;
	}

	.photo-trigger:hover .photo-hover-note,
	.photo-trigger:focus-visible .photo-hover-note {
		opacity: 1;
		transform: translateY(0);
	}

	.photo-lightbox {
		position: fixed;
		inset: 0;
		z-index: 70;
	}

	.photo-lightbox__backdrop {
		position: absolute;
		inset: 0;
		background: rgb(9 9 11 / 0.84);
		backdrop-filter: blur(6px);
	}

	.photo-lightbox__dialog {
		position: relative;
		z-index: 1;
		height: 100%;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem;
		padding: 1.25rem;
	}

	.photo-lightbox__figure {
		margin: 0;
		display: grid;
		gap: 0.85rem;
		justify-items: center;
	}

	.photo-lightbox__image {
		display: block;
		max-width: min(94vw, 1600px);
		max-height: 82vh;
		width: auto;
		height: auto;
		border-radius: 1rem;
		box-shadow: 0 24px 80px rgb(0 0 0 / 0.35);
		background: rgb(24 24 27);
	}

	.photo-lightbox__caption {
		min-height: 1.5rem;
		text-align: center;
		color: rgb(244 244 245);
		font-size: 0.95rem;
	}

	.photo-lightbox__close,
	.photo-lightbox__nav {
		border: 0;
		color: white;
		background: rgb(255 255 255 / 0.12);
		backdrop-filter: blur(6px);
		cursor: pointer;
	}

	.photo-lightbox__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		font-size: 1.6rem;
		line-height: 1;
	}

	.photo-lightbox__nav {
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		font-size: 2rem;
		line-height: 1;
	}

	:global(body.photo-lightbox-open) {
		overflow: hidden;
	}

	@media (max-width: 720px) {
		.photo-lightbox__dialog {
			grid-template-columns: 1fr;
			padding: 1rem;
		}

		.photo-lightbox__nav {
			position: absolute;
			bottom: 1rem;
		}

		.photo-lightbox__nav--prev {
			left: 1rem;
		}

		.photo-lightbox__nav--next {
			right: 1rem;
		}

		.photo-lightbox__image {
			max-width: 100%;
			max-height: 78vh;
		}
	}
</style>
