---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import { projects } from '../../data/projects';
---

<BaseLayout title='纸上电路，用 A-Z a-z 构造的成就' description='一些自己写过、维护过，或真正跟着学过的公开仓库。'>
	<div class='container'>
		<div class='mb-10'>
			<h1 class='text-3xl font-bold mb-2'>纸上电路，用 A-Z a-z 构造的成就</h1>
			<p class='text-zinc-700 dark:text-zinc-300'>此处收录我自己写过、维护过，或跟着学过的代码流。代码有时像草稿，有时像工具，但总归是把脑子里的念头落到屏幕上的痕迹</p>
		</div>
		<ProjectList projects={projects} />
	</div>
</BaseLayout>
