---
import BaseLayout from '@src/layouts/BaseLayout.astro';
import { getTaggedContent, getTagHref, type TagEntry } from '@src/lib/tags';

const { sections } = await getTaggedContent();
const title = '检索标签 / All Tags';
const description = '按文章、随笔、捣鼓玩意和随手拍分组展示站内使用过的标签，中文标签和英文标签分开展示';

const hasCjkText = (value: string) => /[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/u.test(value);
const groupTagsByLanguage = (tags: TagEntry[]) => [
	{
		title: '中文标签',
		tags: tags.filter((tag) => hasCjkText(tag.label))
	},
	{
		title: 'English Tags',
		tags: tags.filter((tag) => !hasCjkText(tag.label))
	}
];
---

<BaseLayout title={title} description={description}>
	<div class='container'>
		<div class='mb-10'>
			<h1 class='text-3xl font-bold mb-2'>{title}</h1>
			<p class='leading-7 text-zinc-700 dark:text-zinc-300'>{description}</p>
		</div>

		<div class='grid gap-8'>
			{
				sections.map((section) => (
					<section class='border-b border-zinc-200 pb-7 dark:border-b-zinc-700'>
						<div class='mb-4'>
							<h2 class='text-2xl font-bold text-zinc-900 dark:text-zinc-100'>{section.title}</h2>
							<p class='mt-1 text-sm text-zinc-600 dark:text-zinc-400'>{section.description}</p>
						</div>
						{section.tags.length === 0 ? (
							<p class='text-sm text-zinc-500 dark:text-zinc-400'>暂无标签。</p>
						) : (
							<div class='grid gap-4'>
								{groupTagsByLanguage(section.tags).map((group) =>
									group.tags.length > 0 ? (
										<div>
											<h3 class='mb-2 text-sm font-semibold text-zinc-700 dark:text-zinc-300'>{group.title}</h3>
											<div class='flex flex-wrap gap-2'>
												{group.tags.map((tag: TagEntry) => (
													<a
														class='rounded-2xl border border-zinc-300 px-3 py-1 text-sm text-zinc-700 no-underline transition-all duration-700 hover:border-zinc-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-300'
														href={getTagHref(tag.value, section.key)}
													>
														{tag.label} ({tag.itemCount})
													</a>
												))}
											</div>
										</div>
									) : null
								)}
							</div>
						)}
					</section>
				))
			}
		</div>
	</div>
</BaseLayout>
