---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import TwikooComments from '../../components/TwikooComments.astro';
import { SITE_TITLE } from '../../consts';

type Props = CollectionEntry<'fragments'>;

export async function getStaticPaths() {
	const fragments = await getCollection('fragments');
	return fragments.map((fragment) => ({
		params: { slug: fragment.id },
		props: fragment
	}));
}

const fragment = Astro.props as Props;
const { Content } = await render(fragment);
const { title, description, pubDate, location, weather } = fragment.data;
const fragmentMeta = [location, weather].filter(Boolean).join(' · ');
---

<BaseLayout title={`${title} - ${SITE_TITLE}`} description={description}>
	<div class='container max-w-3xl'>
		<article>
			<header class='mb-6 border-b border-zinc-200 dark:border-zinc-700 pb-4'>
				<a
					href='/fragments/'
					class='mb-4 inline-flex items-center gap-2 text-sm font-medium no-underline text-zinc-500 transition-colors duration-300 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100'
				>
					<span aria-hidden='true'>←</span>
					<span>返回 Fragments</span>
				</a>
				<div class='flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between'>
					<h1 class='m-0 text-3xl font-semibold leading-tight'>{title}</h1>
					<p class='m-0 shrink-0 text-sm text-zinc-500 dark:text-zinc-400 sm:pt-1 sm:text-right'>
						<time>{pubDate.toLocaleDateString('zh-CN')}</time>
						{fragmentMeta && <span> · {fragmentMeta}</span>}
					</p>
				</div>
			</header>

			<Prose>
				<div class='note-detail'>
					<Content />
				</div>
			</Prose>
			<TwikooComments path={Astro.url.pathname} />
		</article>
	</div>
</BaseLayout>

<style>
	.note-detail :global(p) {
		line-height: 1.95;
		margin: 0 0 1.2rem;
		text-indent: 2em;
	}
</style>
