---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

type FragmentPost = CollectionEntry<'fragments'>;
const fragments = (await getCollection('fragments')).sort((a: FragmentPost, b: FragmentPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const stripMarkdown = (content: string) =>
	content
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/`[^`]*`/g, ' ')
		.replace(/!\[.*?\]\(.*?\)/g, ' ')
		.replace(/\[([^\]]+)\]\((.*?)\)/g, '$1')
		.replace(/<[^>]+>/g, ' ')
		.replace(/^#{1,6}\s+/gm, '')
		.replace(/[*_~>-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

const countReadableText = (content: string) => {
	const plainText = stripMarkdown(content);
	const cjkCount = (plainText.match(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu) || [])
		.length;
	const latinWordCount = (
		plainText
			.replace(/[\p{Script=Han}\p{Script=Hiragana}\p{Script=Katakana}\p{Script=Hangul}]/gu, ' ')
			.match(/[A-Za-z0-9]+(?:['’-][A-Za-z0-9]+)*/g) || []
	).length;

	return {
		characterCount: cjkCount + latinWordCount
	};
};
---

<BaseLayout title={`Fragments - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='mb-8'>
				<h1 class='text-3xl font-semibold mb-2'>一时兴致，脑海的灵光闪烁</h1>
			<p class='text-zinc-700 dark:text-zinc-300'>
				这里收录比文章更短、更即时的想法碎片
			</p>
		</div>

		<div class='space-y-4'>
			{
					fragments.map((note) => (
					<article class='rounded-xl border border-zinc-200 dark:border-zinc-700 px-5 py-4 bg-white dark:bg-zinc-900'>
						<div class='flex items-start justify-between gap-4'>
							<h2 class='m-0 min-w-0 flex-1 text-lg font-semibold leading-tight'>
								<a class='no-underline text-zinc-900 dark:text-zinc-100' href={`/fragments/${note.id}/`}>
								{note.data.title}
							</a>
							</h2>
							{
								(note.data.tags || []).length > 0 && (
									<div class='ml-4 flex shrink-0 flex-wrap justify-end gap-2'>
									{
										(note.data.tags || []).map((tag) => (
											<span
												class='rounded-2xl border border-zinc-300 px-2 py-0.5 text-xs text-zinc-700 dark:border-zinc-700 dark:text-zinc-300'
											>
												{tag}
											</span>
										))
									}
									</div>
								)
							}
						</div>
						<p class='mt-2 mb-0 text-sm leading-6 text-zinc-700 dark:text-zinc-200'>{note.data.description}</p>
						<div class='mt-2 flex flex-wrap gap-2 text-xs text-zinc-500 dark:text-zinc-400'>
							<time>{note.data.pubDate.toLocaleDateString('zh-CN')}</time>
							{(note.data.location || note.data.weather) && (
								<span>· {[note.data.location, note.data.weather].filter(Boolean).join(' · ')}</span>
							)}
							<span>· 约 {countReadableText(note.body).characterCount} 字</span>
						</div>
					</article>
				))
			}
		</div>
	</div>
</BaseLayout>
