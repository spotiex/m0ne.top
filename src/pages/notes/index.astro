---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

type NotePost = CollectionEntry<'notes'>;
const notes = (await getCollection('notes')).sort((a: NotePost, b: NotePost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`Notes - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class='container'>
		<div class='mb-8'>
			<h1 class='text-3xl font-semibold mb-2'>随笔 / Notes</h1>
			<p class='text-zinc-700 dark:text-zinc-300'>
				这里收录比文章更短、更即时的想法碎片。
			</p>
		</div>

		<div class='space-y-4'>
			{
				notes.map((note) => (
					<article class='rounded-xl border border-zinc-200 dark:border-zinc-700 px-5 py-4 bg-white dark:bg-zinc-900'>
						<h2 class='m-0 text-lg font-semibold leading-relaxed'>
							<a class='no-underline text-zinc-900 dark:text-zinc-100' href={`/notes/${note.id}/`}>
								{note.data.title}
							</a>
						</h2>
						<p class='mt-3 mb-0 leading-8 text-zinc-700 dark:text-zinc-200'>{note.data.description}</p>
						<div class='mt-3 text-xs text-zinc-500 dark:text-zinc-400 flex gap-2'>
							<time>{note.data.pubDate.toLocaleDateString('zh-CN')}</time>
							{note.data.mood && <span>· {note.data.mood}</span>}
						</div>
					</article>
				))
			}
		</div>
	</div>
</BaseLayout>
